{
  "name": "@inntend/convert",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "license": "MIT",
  "engines": {
    "pnpm": ">=9",
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "validate": "pnpm run check && pnpm run build:check && pnpm run test:coverage",
    "check": "biome check --write",
    "check:ci": "biome ci",
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "big.js": "^7.0.1",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/big.js": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inntend/convert.git"
  },
  "keywords": [
    "esm",
    "tree-shakeable",
    "typescript",
    "units",
    "conversion",
    "convert"
  ],
  "bugs": {
    "url": "https://github.com/inntend/convert/issues"
  },
  "homepage": "https://github.com/inntend/convert/"
}
